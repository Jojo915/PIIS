{
  "name": "semantic-canvas",
  "displayName": "Semantic Canvas",
  "description": "VS Code notebook semantic canvas extension",
  "version": "0.0.1",
  "publisher": "undefined_publisher",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "*"
  ],
  "contributes": {
    "commands": [
      {
        "command": "semanticCanvas.indexNotebook",
        "title": "Semantic Canvas: Index Notebook"
      },
      {
        "command": "semanticCanvas.debugInfo",
        "title": "Semantic Canvas: Debug Info"
      },
      {
      "command": "semanticCanvas.focusSearch",
      "title": "Semantic Canvas: Focus Search"
      }
    ],
    "keybindings": [
      {
      "command": "semanticCanvas.focusSearch",
      "key": "ctrl+f",
      "mac": "cmd+f",
      "when": "notebookEditorFocused"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "semanticCanvas",
          "title": "Semantic Canvas",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "semanticCanvas": [
        {
          "type": "webview",
          "id": "semanticCanvas.sidebar",
          "name": "Canvas"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.19.42",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.0"
  }
}
